/* components/custom-tabbar/custom-tabbar.wxss */

.bottom-banner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #E8B88A;
  border-radius: 32rpx 32rpx 0 0;
  padding: 28rpx 48rpx;
  margin: 0 16rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-stars {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.banner-sub {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
  letter-spacing: 2rpx;
}

.banner-decor {
  width: 120rpx;
  height: 120rpx;
}

.custom-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 24rpx 20rpx;
  z-index: 100;
}

.tabbar-inner {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 16rpx 8rpx 20rpx;
  box-shadow: 0 -4rpx 24rpx rgba(196, 149, 106, 0.12);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: 8rpx 0;
}

.tab-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 6rpx;
  opacity: 0.45;
}

.tab-label {
  font-size: 22rpx;
  color: #B8A88A;
}

.tab-item.active .tab-icon {
  opacity: 1;
}

.tab-item.active .tab-label {
  color: #C4956A;
  font-weight: 600;
}
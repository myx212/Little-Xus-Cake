/* pages/login/login.wxss */

page {
  background-color: #FEFFEF;
}

.login-page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

/* 全屏背景图 */
.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 右上角小标 */
.corner-badge {
  position: absolute;
  top: 20rpx;
  right: 32rpx;
  background-color: #C48657;
  border-radius: 24rpx;
  padding: 8rpx 20rpx;
  z-index: 2;
}

.badge-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 登录按钮 */
.login-btn-area {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  padding: 0 80rpx;
  z-index: 2;
}

.login-btn {
  width: 100%;
  background-color: #C48657;
  border-radius: 40rpx;
  padding: 10rpx 0;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(196, 149, 106, 0.25);
}

.login-btn::after {
  border: none;
}

.login-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 昵称输入弹窗 */
.nickname-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nickname-mask-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
}

.nickname-popup {
  width: 560rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5C4A32;
  text-align: center;
  display: block;
  margin-bottom: 32rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  background-color: #F5EDE3;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #5C4A32;
  box-sizing: border-box;
}

.popup-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.popup-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  margin: 0;
}

.popup-btn::after {
  border: none;
}

.popup-btn.cancel {
  background-color: #F5EDE3;
  color: #B8A88A;
}

.popup-btn.confirm {
  background-color: #C4956A;
  color: #FFFFFF;
}
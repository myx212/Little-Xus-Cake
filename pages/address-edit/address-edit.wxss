/* pages/address-edit/address-edit.wxss */

page {
  background-color: #FEFFEF;
}

.edit-page {
  min-height: 100vh;
  background-color: #FEFFEF;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* 地址选择卡片 */
.address-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(139, 111, 71, 0.06);
}

.address-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.address-main {
  flex: 1;
}

.address-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #5C4A32;
  display: block;
  margin-bottom: 10rpx;
}

.address-detail {
  font-size: 24rpx;
  color: #B8A88A;
  display: block;
  line-height: 1.5;
}

.change-btn {
  font-size: 26rpx;
  color: #D4878A;
  white-space: nowrap;
  margin-left: 16rpx;
  padding-top: 8rpx;
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F0E8;
}

.form-row:first-of-type {
  border-radius: 16rpx 16rpx 0 0;
}

.form-row:last-of-type {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #5C4A32;
  width: 165rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #5C4A32;
}

.contact-input {
  margin-right: 16rpx;
}

/* 性别选择 */
.gender-group {
  display: flex;
  gap: 24rpx;
  flex-shrink: 0;
}

.gender-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.gender-radio {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #D4C5B0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gender-radio.checked {
  border-color: #D4B896;
  background-color: #D4B896;
}

.gender-radio.checked::after {
  content: '';
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
}

.gender-text {
  font-size: 26rpx;
  color: #8A7A66;
}

/* 标签 */
.tag-group {
  display: flex;
  gap: 16rpx;
  flex: 1;
}

.tag-item {
  padding: 10rpx 32rpx;
  border: 2rpx solid #E8DFD0;
  border-radius: 24rpx;
  background-color: #FFFFFF;
}

.tag-item.active {
  border-color: #D4B896;
  background-color: #FFF3E8;
}

.tag-text {
  font-size: 26rpx;
  color: #8A7A66;
}

.tag-item.active .tag-text {
  color: #D4B896;
  font-weight: 600;
}

/* 默认地址开关 */
.default-row {
  justify-content: space-between;
  border-radius: 0 0 16rpx 16rpx;
}

.switch {
  width: 80rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background-color: #E8DFD0;
  position: relative;
  transition: background-color 0.3s;
}

.switch.on {
  background-color: #D4B896;
}

.switch-knob {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: left 0.3s;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.switch.on .switch-knob {
  left: 40rpx;
}

/* 保存按钮区域 */
.save-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FEFFEF;
  padding: 28rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: center;
  z-index: 100;
}

.save-btn {
  background-color: #FFFFFF;
  border: 2rpx solid #D4B896;
  border-radius: 40rpx;
  padding: 18rpx 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn-text {
  font-size: 30rpx;
  color: #D4B896;
  font-weight: 600;
}
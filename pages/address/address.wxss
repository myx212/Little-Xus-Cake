/* pages/address/address.wxss */

page {
  background-color: #FEFFEF;
}

.address-page {
  min-height: 100vh;
  background-color: #FEFFEF;
  padding-bottom: 120rpx;
}

/* 空状态 */
.empty-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.empty-icon-wrap {
  width: 200rpx;
  height: 200rpx;
  background-color: #FFF0F0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B8A88A;
  margin-bottom: 32rpx;
}

.add-btn {
  background-color: #FFFFFF;
  border: 2rpx solid #C4956A;
  border-radius: 40rpx;
  padding: 18rpx 80rpx;
}

.add-btn-text {
  font-size: 30rpx;
  color: #C4956A;
  font-weight: 600;
}

/* 地址列表 */
.address-list {
  padding: 20rpx;
}

.address-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(139, 111, 71, 0.06);
  display: flex;
  align-items: flex-start;
}

/* 左侧单选按钮 */
.address-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #D4C5B0;
  flex-shrink: 0;
  margin-top: 8rpx;
  margin-right: 20rpx;
}

.address-radio.checked {
  border-color: #D4B896;
  background-color: #D4B896;
  position: relative;
}

.address-radio.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
}

/* 地址信息区域 */
.address-info {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.tag-default {
  font-size: 20rpx;
  color: #5B9BD5;
  background-color: #E8F4FD;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #5C4A32;
  margin-right: 16rpx;
}

.address-phone {
  font-size: 26rpx;
  color: #B8A88A;
}

.address-detail {
  font-size: 26rpx;
  color: #8A7A66;
  line-height: 1.6;
  display: block;
}

/* 右侧编辑图标 */
.address-edit-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.edit-icon-text {
  font-size: 32rpx;
  color: #B8A88A;
}
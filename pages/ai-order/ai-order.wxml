<!--pages/ai-order/ai-order.wxml-->
<view class="page-container">

  <!-- 聊天区域 -->
  <scroll-view class="chat-area" scroll-y scroll-into-view="{{scrollToId}}" scroll-with-animation enable-back-to-top>

    <!-- AI 欢迎消息 -->
    <view class="message ai-message" id="msg-0">
      <image class="ai-avatar" src="/images/ai/ai.png" mode="aspectFit" />
      <view class="ai-bubble">
        <text class="bubble-text">嗨~</text>
        <text class="bubble-text">今儿想吃点什么呢？</text>
      </view>
    </view>

    <!-- 步骤1：选择场景 -->
    <view class="option-list" wx:if="{{step === 1}}" id="msg-1">
      <view class="option-btn" bindtap="onSceneSelect" data-scene="craving">
        <text class="option-icon">🍰</text>
        <text class="option-text">想吃甜品解解馋</text>
      </view>
      <view class="option-btn" bindtap="onSceneSelect" data-scene="healthy">
        <text class="option-icon">🥗</text>
        <text class="option-text">想要低糖/健康一点</text>
      </view>
      <view class="option-btn" bindtap="onSceneSelect" data-scene="afternoon">
        <text class="option-icon">☕</text>
        <text class="option-text">想要下午茶搭配</text>
      </view>
      <view class="option-btn" bindtap="onSceneSelect" data-scene="random">
        <text class="option-icon">🎲</text>
        <text class="option-text">不知道，随便推荐</text>
      </view>
    </view>

    <!-- 用户选择的场景 -->
    <view class="message user-message" wx:if="{{step >= 2}}" id="msg-user-scene">
      <view class="user-bubble">
        <text class="bubble-text">{{userSceneText || sceneText}}</text>
      </view>
    </view>

    <!-- AI 回复场景选择 -->
    <view class="message ai-message" wx:if="{{step >= 2}}" id="msg-2">
      <image class="ai-avatar" src="/images/ai/ai.png" mode="aspectFit" />
      <view class="ai-bubble">
        <text class="bubble-text">好的！</text>
        <text class="bubble-text">你更喜欢什么口味呢？</text>
      </view>
    </view>

    <!-- 步骤2：选择口味 -->
    <view class="option-list" wx:if="{{step === 2}}" id="msg-3">
      <view class="option-btn flavor-btn {{flavor === 'fruit' ? 'selected' : ''}}" bindtap="onFlavorSelect" data-flavor="fruit">
        <text class="option-icon"></text>
        <text class="option-text">水果口味</text>
        <view class="check-icon" wx:if="{{flavor === 'fruit'}}">✓</view>
      </view>
      <view class="option-btn flavor-btn {{flavor === 'chocolate' ? 'selected' : ''}}" bindtap="onFlavorSelect" data-flavor="chocolate">
        <text class="option-icon">🍫</text>
        <text class="option-text">巧克力口味</text>
        <view class="check-icon" wx:if="{{flavor === 'chocolate'}}">✓</view>
      </view>
      <view class="option-btn flavor-btn {{flavor === 'milk' ? 'selected' : ''}}" bindtap="onFlavorSelect" data-flavor="milk">
        <text class="option-icon">🥛</text>
        <text class="option-text">奶香口味</text>
        <view class="check-icon" wx:if="{{flavor === 'milk'}}">✓</view>
      </view>
      <view class="option-btn flavor-btn {{flavor === 'matcha' ? 'selected' : ''}}" bindtap="onFlavorSelect" data-flavor="matcha">
        <text class="option-icon"></text>
        <text class="option-text">抹茶口味</text>
        <view class="check-icon" wx:if="{{flavor === 'matcha'}}">✓</view>
      </view>
    </view>

    <!-- 用户选择的口味 -->
    <view class="message user-message" wx:if="{{step >= 3}}" id="msg-user-flavor">
      <view class="user-bubble">
        <text class="bubble-text">{{userFlavorText || flavorText}}</text>
      </view>
    </view>

    <!-- AI 回复口味选择 -->
    <view class="message ai-message" wx:if="{{step >= 3}}" id="msg-4">
      <image class="ai-avatar" src="/images/ai/ai.png" mode="aspectFit" />
      <view class="ai-bubble">
        <text class="bubble-text">了解了！</text>
        <text class="bubble-text">预算大概是多少呢？</text>
      </view>
    </view>

    <!-- 步骤3：选择预算 -->
    <view class="option-list budget-list" wx:if="{{step === 3}}" id="msg-5">
      <view class="option-btn budget-btn {{budget === 'low' ? 'selected' : ''}}" bindtap="onBudgetSelect" data-budget="low">
        <text class="option-text">20元以内</text>
        <view class="check-icon" wx:if="{{budget === 'low'}}">✓</view>
      </view>
      <view class="option-btn budget-btn {{budget === 'mid' ? 'selected' : ''}}" bindtap="onBudgetSelect" data-budget="mid">
        <text class="option-text">20-40元</text>
        <view class="check-icon" wx:if="{{budget === 'mid'}}">✓</view>
      </view>
      <view class="option-btn budget-btn {{budget === 'high' ? 'selected' : ''}}" bindtap="onBudgetSelect" data-budget="high">
        <text class="option-text">40-60元</text>
        <view class="check-icon" wx:if="{{budget === 'high'}}">✓</view>
      </view>
      <view class="option-btn budget-btn {{budget === 'luxury' ? 'selected' : ''}}" bindtap="onBudgetSelect" data-budget="luxury">
        <text class="option-text">60元以上</text>
        <view class="check-icon" wx:if="{{budget === 'luxury'}}">✓</view>
      </view>
    </view>

    <!-- 用户选择的预算 -->
    <view class="message user-message" wx:if="{{step >= 4}}" id="msg-user-budget">
      <view class="user-bubble">
        <text class="bubble-text">{{userBudgetText || budgetText}}</text>
      </view>
    </view>

    <!-- AI 思考中 -->
    <view class="message ai-message" wx:if="{{step === 4}}" id="msg-6">
      <image class="ai-avatar" src="/images/ai/ai.png" mode="aspectFit" />
      <view class="ai-bubble thinking-bubble">
        <view class="thinking-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>
    </view>

    <!-- AI 推荐结果 -->
    <view class="message ai-message" wx:if="{{step >= 5}}" id="msg-7">
      <image class="ai-avatar" src="/images/ai/ai.png" mode="aspectFit" />
      <view class="ai-bubble">
        <text class="bubble-text">根据你的喜好，</text>
        <text class="bubble-text">为你推荐以下甜品~</text>
      </view>
    </view>

    <!-- 推荐商品卡片 -->
    <view class="goods-list" wx:if="{{step >= 5}}" id="msg-8">
      <view class="goods-card" wx:for="{{recommendGoods}}" wx:key="_id">
        <image class="goods-img" src="{{item.image}}" mode="aspectFill" />
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-price">¥{{item.price}}</text>
        </view>
        <!-- 数量控制 -->
        <view class="qty-control">
          <view class="qty-btn {{item.quantity > 0 ? '' : 'disabled'}}" catchtap="onRemoveItem" data-index="{{index}}">
            <text class="qty-btn-text">−</text>
          </view>
          <text class="qty-num" wx:if="{{item.quantity > 0}}">x{{item.quantity}}</text>
          <view class="qty-btn add-btn" catchtap="onAddSingle" data-index="{{index}}">
            <text class="qty-btn-text">+</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 套餐汇总 -->
    <view class="combo-summary" wx:if="{{step >= 5}}" id="msg-9">
      <view class="combo-total">
        <text class="combo-label">合计：</text>
        <text class="combo-price">¥{{comboTotal}}</text>
      </view>
    </view>

    <!-- 底部留白 -->
    <view style="height: 140rpx;"></view>
  </scroll-view>

  <!-- 底部操作区（推荐结果时：一键下单） -->
  <view class="bottom-bar" wx:if="{{step >= 5}}">
    <view class="order-btn" bindtap="onOrderNow">
      <text class="order-btn-text">一键下单</text>
    </view>
  </view>

  <!-- 文字输入栏（步骤1-4时显示，替换按住说话） -->
  <view class="input-bar" wx:if="{{step >= 1 && step <= 4}}">
    <input class="input-field" placeholder="输入你想吃的..." value="{{inputText}}" bindinput="onInputText" bindconfirm="onSendText" confirm-type="send" />
    <view class="send-btn" bindtap="onSendText">
      <text class="send-icon">↑</text>
    </view>
  </view>

</view>

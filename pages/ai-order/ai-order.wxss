/* pages/ai-order/ai-order.wxss */

page {
  background-color: #FFF8F5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #FFF8F5;
}

/* 顶部标题栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background-color: #FFF8F5;
}

.header-left, .header-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333;
  font-weight: 300;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* 聊天区域 */
.chat-area {
  flex: 1;
  padding: 20rpx 32rpx;
  padding-bottom: 220rpx;
  box-sizing: border-box;
}

/* 消息气泡 */
.message {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.ai-message {
  justify-content: flex-start;
}

.user-message {
  justify-content: flex-end;
}

.ai-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.ai-bubble {
  background: #FFFFFF;
  border-radius: 24rpx;
  border-top-left-radius: 6rpx;
  padding: 22rpx 28rpx;
  max-width: 65%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-bubble {
  background: #FFFFFF;
  border-radius: 24rpx;
  border-top-right-radius: 6rpx;
  padding: 22rpx 28rpx;
  max-width: 65%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

/* 选项列表 */
.option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.option-btn {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border: 2rpx solid #F0E8E4;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  transition: all 0.2s ease;
}

.option-btn:active {
  transform: scale(0.98);
  background: #FFF0F0;
}

.option-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.option-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 选中状态 */
.option-btn.selected {
  border-color: #F5A0A0;
  background: #FFF5F5;
}

.check-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #F5A0A0;
  color: #FFFFFF;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 口味按钮 */
.flavor-btn {
  padding: 24rpx 32rpx;
}

/* 预算按钮 */
.budget-list {
  gap: 14rpx;
}

.budget-btn {
  justify-content: space-between;
  padding: 26rpx 32rpx;
}

/* 思考动画 */
.thinking-bubble {
  padding: 24rpx 32rpx;
}

.thinking-dots {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #F5A0A0;
  animation: thinking 1.4s infinite ease-in-out;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes thinking {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.goods-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.goods-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.goods-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #F5A0A0;
}

.goods-add-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #F5A0A0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.add-icon {
  font-size: 38rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* 数量控制 */
.qty-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F5A0A0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.qty-btn.disabled {
  background: #F0D0D0;
  opacity: 0.5;
}

.qty-btn.add-btn {
  background: #F5A0A0;
}

.qty-btn-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

.qty-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  min-width: 40rpx;
  text-align: center;
}

/* 套餐汇总 */
.combo-summary {
  padding: 16rpx 0 20rpx;
}

.combo-total {
  display: flex;
  align-items: baseline;
}

.combo-label {
  font-size: 28rpx;
  color: #666;
}

.combo-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #FFF8F5;
}

.order-btn {
  background: #F5A0A0;
  border-radius: 48rpx;
  padding: 28rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-btn:active {
  opacity: 0.85;
}

.order-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 语音输入栏 */
.voice-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #FFF8F5;
  z-index: 9999;
  pointer-events: auto;
}

.voice-btn {
  background: #F5A0A0;
  border-radius: 48rpx;
  padding: 28rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.15s ease;
}

.voice-btn-hover {
  opacity: 0.8;
  transform: scale(0.97);
}

.voice-btn.recording {
  background: #E89090;
  transform: scale(1.02);
}

.voice-icon {
  font-size: 36rpx;
}

.voice-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 文字输入栏 */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #FFF8F5;
  z-index: 9999;
  gap: 16rpx;
}

.input-field {
  flex: 1;
  height: 80rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #F0E8E4;
}

.input-field:focus {
  border-color: #F5A0A0;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F5A0A0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.send-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

<!--pages/stamp/stamp.wxml-->
<view class="stamp-page">

  <!-- 顶部插画区 -->
  <view class="header-area">
    <view class="header-decor-left">
      <image class="stamp-icon" src="/images/cake/one.jpg" mode="aspectFit" />
    </view>
    <view class="header-content">
      <text class="header-title">集章领礼券</text>
      <text class="header-sub">集满6个杯章，即可获得任意券</text>
    </view>
    <view class="header-decor-right">
      <image class="coffee-icon" src="/images/cake/two.jpg" mode="aspectFit" />
    </view>
  </view>

  <!-- 进度卡片 -->
  <view class="progress-card">
    <view class="progress-header">
      <text class="progress-label">已获得</text>
      <text class="progress-count">{{collectedCount}}</text>
      <text class="progress-label">杯章</text>
    </view>

    <!-- 徽章网格 -->
    <view class="badge-grid">
      <view
        class="badge-item {{item.collected ? 'collected' : 'locked'}}"
        wx:for="{{badges}}"
        wx:key="index"
      >
        <view class="badge-circle">
          <image
            class="badge-image {{item.collected ? '' : 'grayed'}}"
            src="{{item.image}}"
            mode="aspectFit"
          />
        </view>
      </view>
    </view>
  </view>

  <!-- 记录Tab -->
  <view class="record-tabs">
    <view
      class="record-tab {{currentRecordTab === 'stamp' ? 'active' : ''}}"
      bindtap="onSwitchRecordTab"
      data-tab="stamp"
    >
      <text class="tab-icon">📋</text>
      <text class="tab-label">集章记录</text>
    </view>
    <view
      class="record-tab {{currentRecordTab === 'exchange' ? 'active' : ''}}"
      bindtap="onSwitchRecordTab"
      data-tab="exchange"
    >
      <text class="tab-icon">🎟️</text>
      <text class="tab-label">兑换记录</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="record-list" wx:if="{{currentRecordTab === 'stamp'}}">
    <view class="record-item" wx:for="{{stampRecords}}" wx:key="index">
      <text class="record-text">{{item.text}}</text>
      <text class="record-time">{{item.time}}</text>
    </view>
    <view class="empty-record" wx:if="{{stampRecords.length === 0}}">
      <text class="empty-text">暂无集章记录</text>
    </view>
  </view>

  <view class="record-list" wx:if="{{currentRecordTab === 'exchange'}}">
    <view class="record-item" wx:for="{{exchangeRecords}}" wx:key="index">
      <text class="record-text">{{item.text}}</text>
      <text class="record-time">{{item.time}}</text>
    </view>
    <view class="empty-record" wx:if="{{exchangeRecords.length === 0}}">
      <text class="empty-text">暂无兑换记录</text>
    </view>
  </view>

  <!-- 活动说明 -->
  <view class="rules-card">
    <text class="rules-title">活动说明</text>
    <view class="rules-list">
      <text class="rules-item">1、每购买一次指定商品可获得，累计满6件商品可领取奖品</text>
      <text class="rules-item">2、本次活动仅指定分类甜品可参与</text>
      <text class="rules-item">3、本次活动仅本店可用</text>
      <text class="rules-item">4、2026-10-01 23:59:59可用</text>
      <text class="rules-item">5、完成本次活动可领取奖品优惠券"任意兑换券"</text>
    </view>
  </view>

</view>
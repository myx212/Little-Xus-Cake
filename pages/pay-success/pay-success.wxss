/* pages/pay-success/pay-success.wxss */

page {
  background-color: #FEFFEF;
}

.page {
  min-height: 100vh;
  background-color: #FEFFEF;
  padding-bottom: 180rpx;
}

/* 订单号 */
.order-no-area {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.order-no-label {
  display: block;
  font-size: 24rpx;
  color: #B8A88A;
  margin-bottom: 8rpx;
}

.order-no {
  font-size: 72rpx;
  font-weight: 700;
  color: #5C4A32;
  letter-spacing: 8rpx;
}

/* 进度条 */
.progress-area {
  padding: 20rpx 40rpx;
}

.progress-steps {
  display: flex;
  align-items: center;
  justify-content: center;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #F0E6D8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step.active .step-icon {
  background-color: #C4956A;
}

.step-icon-text {
  font-size: 30rpx;
}

.step-label {
  font-size: 22rpx;
  color: #B8A88A;
  margin-top: 8rpx;
}

.step.active .step-label {
  color: #C4956A;
  font-weight: 600;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background-color: #F0E6D8;
  margin: 0 8rpx;
  margin-bottom: 28rpx;
}

.step-line.active {
  background-color: #C4956A;
}

/* 状态提示 */
.status-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 40rpx;
  margin: 8rpx 24rpx;
  background-color: #F0FFF0;
  border-radius: 12rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #4CAF50;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.status-text {
  font-size: 24rpx;
  color: #4CAF50;
}

/* 本单获得 */
.reward-section {
  background-color: #FFFFFF;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
}

.reward-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5C4A32;
}

.reward-subtitle {
  font-size: 22rpx;
  color: #B8A88A;
  margin-left: 12rpx;
}

.reward-tags {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.reward-tag {
  display: flex;
  align-items: center;
  background-color: #FFF8F0;
  border-radius: 24rpx;
  padding: 10rpx 20rpx;
}

.tag-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.tag-text {
  font-size: 24rpx;
  color: #C4956A;
}

/* 店铺信息 */
.shop-section {
  background-color: #FFFFFF;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
}

.shop-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.shop-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #5C4A32;
}

.shop-checks {
  display: flex;
  gap: 8rpx;
}

.check-mark {
  font-size: 28rpx;
  color: #4CAF50;
}

.shop-address {
  font-size: 24rpx;
  color: #B8A88A;
}

/* 商品列表 */
.goods-section {
  background-color: #FFFFFF;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  padding: 8rpx 28rpx;
}

.goods-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0E6D8;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background-color: #F8F0E4;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #5C4A32;
  margin-bottom: 4rpx;
}

.goods-desc {
  font-size: 22rpx;
  color: #B8A88A;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.goods-right {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #5C4A32;
}

.goods-qty {
  font-size: 24rpx;
  color: #B8A88A;
}

/* 合计 */
.total-bar {
  display: flex;
  justify-content: flex-end;
  align-items: baseline;
  padding: 20rpx 40rpx;
  gap: 12rpx;
}

.total-label {
  font-size: 24rpx;
  color: #B8A88A;
}

.total-text {
  font-size: 24rpx;
  color: #B8A88A;
}

.total-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #5C4A32;
}

/* 就餐信息 */
.dining-section {
  background-color: #FFFFFF;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5C4A32;
  display: block;
  margin-bottom: 20rpx;
}

.dining-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.dining-label {
  font-size: 28rpx;
  color: #B8A88A;
}

.dining-value {
  font-size: 28rpx;
  color: #5C4A32;
  font-weight: 500;
}

/* 底部按钮 */
.bottom-btns {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(139, 111, 71, 0.06);
}

.btn-outline {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 40rpx;
  border: 2rpx solid #C4956A;
  text-align: center;
}

.btn-outline-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #C4956A;
}

.btn-primary {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 40rpx;
  background-color: #C4956A;
  text-align: center;
}

.btn-primary-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}
<!--pages/pay-success/pay-success.wxml-->
<view class="page">

  <!-- 订单号 -->
  <view class="order-no-area">
    <text class="order-no-label">取餐号</text>
    <text class="order-no">{{orderNo}}</text>
  </view>

  <!-- 订单进度 -->
  <view class="progress-area">
    <view class="progress-steps">
      <view class="step {{currentStep >= 1 ? 'active' : ''}}">
        <view class="step-icon">
          <text class="step-icon-text">📋</text>
        </view>
        <text class="step-label">已下单</text>
      </view>
      <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
      <view class="step {{currentStep >= 2 ? 'active' : ''}}">
        <view class="step-icon">
          <text class="step-icon-text">👨‍</text>
        </view>
        <text class="step-label">制作中</text>
      </view>
      <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
      <view class="step {{currentStep >= 3 ? 'active' : ''}}">
        <view class="step-icon">
          <text class="step-icon-text">📦</text>
        </view>
        <text class="step-label">待取餐</text>
      </view>
    </view>
  </view>

  <!-- 状态提示 -->
  <view class="status-bar">
    <view class="status-dot"></view>
    <text class="status-text">您的订单正在制作中，预计等待{{waitTime}}分钟</text>
  </view>

  <!-- 本单获得 -->
  <view class="reward-section">
    <text class="reward-title">本单获得</text>
    <text class="reward-subtitle">以实际发放为准</text>
    <view class="reward-tags">
      <view class="reward-tag">
        <text class="tag-icon">🎂</text>
        <text class="tag-text">糕点 x1</text>
      </view>
      <view class="reward-tag">
        <text class="tag-icon">⭐</text>
        <text class="tag-text">积分 +{{rewardPoints}}</text>
      </view>
      <view class="reward-tag">
        <text class="tag-icon">🌱</text>
        <text class="tag-text">成长值 +{{rewardPoints}}</text>
      </view>
    </view>
  </view>

  <!-- 店铺信息 -->
  <view class="shop-section">
    <view class="shop-header">
      <text class="shop-name">Little Xu's Cake</text>
      <view class="shop-checks">
        <text class="check-mark">✓</text>
        <text class="check-mark">✓</text>
      </view>
    </view>
    <text class="shop-address">营业时间 8:00-21:00，每周二店休</text>
  </view>

  <!-- 商品列表 -->
  <view class="goods-section">
    <view class="goods-item" wx:for="{{goodsList}}" wx:key="_id">
      <image class="goods-img" src="{{item.image}}" mode="aspectFill" />
      <view class="goods-info">
        <text class="goods-name">{{item.name}}</text>
        <text class="goods-desc">{{item.description}}</text>
        <view class="goods-right">
          <text class="goods-price">¥{{item.price}}</text>
          <text class="goods-qty">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 合计 -->
  <view class="total-bar">
    <text class="total-label">共 {{totalCount}} 份</text>
    <text class="total-text">总价</text>
    <text class="total-amount">¥{{payAmount}}</text>
  </view>

  <!-- 就餐信息 -->
  <view class="dining-section">
    <text class="section-title">就餐信息</text>
    <view class="dining-row">
      <text class="dining-label">用餐方式</text>
      <text class="dining-value">{{deliveryMode === 'pickup' ? '自取' : '外卖'}}</text>
    </view>
    <view class="dining-row" wx:if="{{deliveryMode === 'deliver' && deliveryAddress}}">
      <text class="dining-label">配送地址</text>
      <text class="dining-value">{{deliveryAddress}}</text>
    </view>
    <view class="dining-row">
      <text class="dining-label">{{deliveryMode === 'pickup' ? '取餐时间' : '配送时间'}}</text>
      <text class="dining-value">{{pickTime || (deliveryMode === 'pickup' ? '立即取餐' : '尽快配送')}}</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-btns">
    <view class="btn-outline" bindtap="onGoOrder">
      <text class="btn-outline-text">查看订单</text>
    </view>
    <view class="btn-primary" bindtap="onGoHome">
      <text class="btn-primary-text">返回首页</text>
    </view>
  </view>

</view>
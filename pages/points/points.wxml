<!--pages/points/points.wxml-->
<view class="points-page">

  <!-- 顶部Banner -->
  <view class="banner-area">
    <text class="banner-title">超值好礼 换不停</text>
    <view class="banner-decor">
      <text class="gift-icon">🎁</text>
    </view>
  </view>

  <!-- 用户积分卡片 -->
  <view class="points-card">
    <view class="user-info">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/home/cart.jpg'}}" mode="aspectFill" />
      <view class="points-info">
        <text class="points-label">积分</text>
        <text class="points-value">{{totalPoints}}</text>
      </view>
    </view>
    <view class="points-links">
      <text class="points-link" bindtap="onShowDetail">积分明细</text>
      <text class="points-link" bindtap="onShowExchange">兑换记录</text>
    </view>
  </view>

  <!-- 每日签到 -->
  <view class="checkin-card">
    <view class="checkin-header">
      <text class="checkin-title">每日签到</text>
      <view class="checkin-reminder">
        <text class="reminder-text">签到提醒</text>
        <view class="reminder-switch {{reminderOn ? 'on' : ''}}" bindtap="onToggleReminder">
          <view class="reminder-knob"></view>
        </view>
      </view>
    </view>

    <!-- 本周签到日历 -->
    <view class="week-calendar">
      <view
        class="day-item {{item.checked ? 'checked' : ''}} {{item.isToday ? 'today' : ''}}"
        wx:for="{{weekDays}}"
        wx:key="index"
        bindtap="onDayTap"
        data-index="{{index}}"
      >
        <text class="day-name">{{item.name}}</text>
        <view class="day-coin {{item.checked ? 'collected' : ''}}">
          <text class="coin-icon">⭐</text>
        </view>
        <text class="day-points">+{{item.points}}积分</text>
      </view>
    </view>

    <!-- 周进度条 -->
    <view class="week-progress">
      <view class="progress-dots">
        <view
          class="progress-dot {{item.checked ? 'active' : ''}}"
          wx:for="{{weekDays}}"
          wx:key="index"
        ></view>
      </view>
      <view class="progress-labels">
        <text wx:for="{{weekDays}}" wx:key="index" class="progress-label">{{item.shortName}}</text>
      </view>
    </view>

    <!-- 签到按钮 -->
    <view class="checkin-btn {{todayChecked ? 'done' : ''}}" bindtap="onCheckIn">
      <text class="checkin-btn-text">{{todayChecked ? '今日已签到' : '立即签到'}}</text>
    </view>
  </view>

  <!-- 积分商品 -->
  <view class="products-card">
    <text class="products-title">积分商品</text>
    <view class="products-grid">
      <view class="product-item" wx:for="{{products}}" wx:key="_id">
        <image class="product-image" src="{{item.image}}" mode="aspectFill" />
        <text class="product-name">{{item.name}}</text>
        <text class="product-price">单买价 ¥{{item.price}}</text>
        <view class="product-bottom">
          <view class="product-points">
            <text class="points-star">★</text>
            <text class="points-num">{{item.needPoints}}</text>
          </view>
          <view class="exchange-btn" bindtap="onExchange" data-id="{{item._id}}">
            <text class="exchange-text">兑换</text>
          </view>
        </view>
      </view>
    </view>
  </view>

</view>
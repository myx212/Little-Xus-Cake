/* pages/home/home.wxss */

page {
  background-color: #FEFFEF;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.page-container {
  min-height: 100vh;
  background-color: #FEFFEF;
  padding-bottom: 220rpx;
  box-sizing: border-box;
}

/* 顶部品牌区 */
.brand-area {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 60rpx 48rpx 30rpx;
  gap: 20rpx;
}

.brand-logo {
  width: 360rpx;
  height: 200rpx;
}

.brand-decor {
  width: 180rpx;
  height: 180rpx;
}

/* 核心插画区 */
.illustration-area {
  padding: 10rpx 24rpx 30rpx;
}

.illustration-img {
  width: 100%;
  display: block;
}

/* 会员卡片区 */
.member-cards {
  padding: 0 32rpx 30rpx;
}
.color-top {
  background-color: #E8DCD0;
}
.color-next {
  background-color: #E9E0D1;
}
.member-card {
  position: relative;
  
  border-radius: 24rpx;
  padding: 15rpx 65rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
  min-height: 200rpx;
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 1;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #5C4A32;
}

.card-btn {
  display: inline-flex;
  align-items: center;
  background-color: #734A2A;
  border-radius: 32rpx;
  padding: 10rpx 28rpx;
  width: fit-content;
}

.card-btn-text {
  font-size: 24rpx;
  color: #FFFFFF;
}

.card-image {
  width: 200rpx;
  height: 200rpx;
  margin-left: 20rpx;
  z-index: 1;
}

.card-brand {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  z-index: 1;
}

.card-brand-text {
  font-size: 18rpx;
  color: #B8A88A;
  font-style: italic;
}

/* 功能按钮区 */
.function-area {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 32rpx 40rpx;
}

.func-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: 16rpx 0;
}

.func-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
}

.func-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #C4956A;
  margin-bottom: 6rpx;
}

.func-sub {
  font-size: 20rpx;
  color: #B8A88A;
  letter-spacing: 2rpx;
}

/* AI 甜品顾问悬浮按钮 */
.ai-float-btn {
  position: fixed;
  right: 24rpx;
  bottom: 240rpx;
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ai-float-img {
  width: 140rpx;
  height: 140rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(245, 160, 160, 0.35));
}

.ai-float-label {
  background: #F5A0A0;
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  margin-top: -8rpx;
  box-shadow: 0 2rpx 8rpx rgba(245, 160, 160, 0.3);
}

.ai-float-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* VIP 卡片 */
.vip-card {
  margin: 0 32rpx 40rpx;
  background-color: #C4956A;
  border-radius: 24rpx;
  padding: 32rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(196, 149, 106, 0.3);
}

.vip-text-area {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.vip-title {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.vip-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 1rpx;
}

.vip-big {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 700;
  margin-top: 8rpx;
}

.vip-image {
  width: 120rpx;
  height: 120rpx;
}

/* 店铺插画区 */
.store-illustration-area {
  padding: 20rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.store-illustration-img {
  width: 80%;
  display: block;
  margin-bottom: 32rpx;
}

.store-text-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.store-text {
  font-size: 26rpx;
  color: #B8A88A;
  text-align: center;
  letter-spacing: 2rpx;
}

.store-text-en {
  font-size: 24rpx;
  color: #C4956A;
  text-align: center;
  font-style: italic;
  margin: 8rpx 0;
}
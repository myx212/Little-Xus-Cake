/* pages/order-list/order-list.wxss */

page {
  background-color: #FEFFEF;
}

.order-list-page {
  min-height: 100vh;
  background-color: #FEFFEF;
  padding-bottom: 220rpx;
}

/* 顶部Tab */
.top-tabs {
  display: flex;
  background-color: #FFFFFF;
  padding: 20rpx 0;
  overflow-x: auto;
  white-space: nowrap;
  border-bottom: 1rpx solid #F0E6D8;
}

.tab-item {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #8B7B6B;
  position: relative;
}

.tab-item.active {
  color: #C4956A;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #C4956A;
  border-radius: 2rpx;
}

/* 订单列表 */
.order-scroll {
  height: calc(100vh - 120rpx);
  padding: 20rpx;
  box-sizing: border-box;
}

.order-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 111, 71, 0.06);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0E6D8;
  margin-bottom: 16rpx;
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.delivery-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.delivery-tag.deliver {
  background-color: #E8A84C;
  color: #FFFFFF;
}

.delivery-tag.pickup {
  background-color: #C4956A;
  color: #FFFFFF;
}

.order-no {
  font-size: 22rpx;
  color: #B8A88A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-status {
  font-size: 24rpx;
  font-weight: 600;
  color: #E8A84C;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 商品信息 */
.order-body {
  display: flex;
  padding-bottom: 16rpx;
}

.order-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background-color: #F8F0E4;
  margin-right: 20rpx;
}

.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.order-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #5C4A32;
  margin-bottom: 6rpx;
}

.order-desc {
  font-size: 22rpx;
  color: #B8A88A;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.order-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #5C4A32;
}

.order-qty {
  font-size: 24rpx;
  color: #8B7B6B;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #F0E6D8;
}

.order-time {
  font-size: 22rpx;
  color: #B8A88A;
}

.order-total {
  font-size: 26rpx;
  font-weight: 600;
  color: #5C4A32;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.action-btn.outline {
  border: 1rpx solid #E0D5C5;
  color: #8B7B6B;
}

.action-btn.primary {
  border: 1rpx solid #C4956A;
  color: #C4956A;
}

.action-btn.highlight {
  background-color: #E8A84C;
  color: #FFFFFF;
  border: none;
}

.action-text {
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #B8A88A;
}

/* 多商品列表 */
.multi-goods-list {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.multi-goods-item {
  display: flex;
  align-items: stretch;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx dashed #F0E6D8;
}

.multi-goods-item:last-child {
  padding-bottom: 0;
  margin-bottom: 0;
  border-bottom: none;
}

.multi-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 14rpx;
  margin-right: 18rpx;
}

.multi-desc {
  font-size: 20rpx;
  color: #A89678;
}

/* 卡片级备注 */
.order-remark {
  background-color: #FFFBF3;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 14rpx;
  display: flex;
  align-items: flex-start;
}

.remark-label {
  font-size: 22rpx;
  color: #C4956A;
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.remark-text {
  font-size: 22rpx;
  color: #8B7B6B;
  line-height: 1.4;
  flex: 1;
  min-width: 0;
  word-break: break-all;
}
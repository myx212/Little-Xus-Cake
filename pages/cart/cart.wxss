/* pages/cart/cart.wxss */

page {
  background-color: #FEFFEF;
}

.cart-page {
  min-height: 100vh;
  background-color: #FEFFEF;
  padding-bottom: 180rpx;
}

/* 页面标题 */
.page-header {
  text-align: center;
  padding: 24rpx 0 16rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #5C4A32;
}

/* 购物车列表 */
.cart-list {
  padding: 0 24rpx;
}

.cart-card {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(196, 149, 106, 0.08);
}

/* 选择圆圈 */
.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #D4C5B0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.check-circle.checked {
  background-color: #E8A84C;
  border-color: #E8A84C;
}

.check-mark {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 700;
}

/* 商品图 */
.cart-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background-color: #F8F0E4;
  margin-right: 20rpx;
  flex-shrink: 0;
}

/* 商品信息 */
.cart-info {
  flex: 1;
  min-width: 0;
}

.cart-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #5C4A32;
  display: block;
  margin-bottom: 6rpx;
}

.cart-spec {
  font-size: 22rpx;
  color: #B8A88A;
  display: block;
  margin-bottom: 16rpx;
}

/* 数量控制 */
.cart-qty {
  display: flex;
  align-items: center;
}

.cart-qty .qty-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #C4956A;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-qty .qty-icon {
  font-size: 26rpx;
  color: #C4956A;
  font-weight: 700;
  line-height: 1;
}

.cart-qty .qty-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #5C4A32;
  margin: 0 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 价格 */
.cart-price {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.price-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #E8A84C;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #5C4A32;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #B8A88A;
  margin-bottom: 48rpx;
}

.empty-btn {
  background-color: #C4956A;
  border-radius: 40rpx;
  padding: 20rpx 80rpx;
}

.empty-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 优惠减免 */
.coupon-section {
  padding: 24rpx;
}

.coupon-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5C4A32;
  display: block;
  margin-bottom: 16rpx;
}

.coupon-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #FFF8EE;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  border: 2rpx dashed #E8D5BE;
}

.coupon-left {
  display: flex;
  align-items: center;
}

.coupon-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.coupon-info {
  display: flex;
  flex-direction: column;
}

.coupon-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #5C4A32;
}

.coupon-desc {
  font-size: 22rpx;
  color: #B8A88A;
  margin-top: 4rpx;
}

.coupon-action {
  font-size: 26rpx;
  color: #E8A84C;
  font-weight: 600;
}

.coupon-action.coupon-used {
  color: #B8A88A;
}

.coupon-discount-line {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0 0;
}

.discount-text {
  font-size: 24rpx;
  color: #B8A88A;
}

.discount-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #E8A84C;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(139, 111, 71, 0.08);
  z-index: 100;
}

.select-all {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
}

.select-all-text {
  font-size: 26rpx;
  color: #5C4A32;
  margin-left: 10rpx;
}

.total-section {
  flex: 1;
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  margin-right: 20rpx;
}

.total-label {
  font-size: 24rpx;
  color: #8B7B6B;
  margin-right: 8rpx;
}

.total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #E8A84C;
}

.checkout-btn {
  background-color: #E8A84C;
  border-radius: 40rpx;
  padding: 20rpx 48rpx;
  flex-shrink: 0;
}

.checkout-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}
/* pages/recharge/recharge.wxss */

page {
  background-color: #FEFFEF;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.page-container {
  min-height: 100vh;
  background-color: #FEFFEF;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

/* 顶部 Banner */
.recharge-banner {
  position: relative;
  background: linear-gradient(135deg, #E8D5B7 0%, #D4B896 100%);
  padding: 60rpx 40rpx 80rpx;
  overflow: hidden;
}

.banner-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #5C4A32;
  display: block;
}

.banner-sub {
  font-size: 24rpx;
  color: #8A7A66;
  margin-top: 8rpx;
  display: block;
}

.banner-image {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 200rpx;
  height: 200rpx;
  opacity: 0.8;
}

/* 余额卡片 */
.balance-card {
  margin: -40rpx 32rpx 0;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 111, 71, 0.1);
  position: relative;
  z-index: 1;
}

.balance-label {
  font-size: 24rpx;
  color: #B8A88A;
}

.balance-amount {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.balance-symbol {
  font-size: 32rpx;
  color: #5C4A32;
  font-weight: 600;
}

.balance-num {
  font-size: 56rpx;
  color: #5C4A32;
  font-weight: 700;
  margin-left: 4rpx;
}

/* 充值档位 */
.recharge-section {
  padding: 40rpx 32rpx 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5C4A32;
  margin-bottom: 24rpx;
  display: block;
}

.recharge-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.recharge-item {
  width: calc(33.33% - 14rpx);
  background-color: #FFFFFF;
  border: 2rpx solid #E8DDD0;
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
}

.recharge-item.selected {
  border-color: #C4956A;
  background-color: #FFF8F0;
}

.plan-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #5C4A32;
}

.plan-bonus {
  font-size: 22rpx;
  color: #C4956A;
  margin-top: 8rpx;
}

/* 充值说明 */
.recharge-notice {
  margin: 40rpx 32rpx 0;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #5C4A32;
  display: block;
  margin-bottom: 16rpx;
}

.notice-text {
  font-size: 24rpx;
  color: #B8A88A;
  display: block;
  line-height: 1.8;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #FEFFEF;
  box-shadow: 0 -2rpx 12rpx rgba(139, 111, 71, 0.06);
}

.pay-btn {
  background-color: #C4956A;
  border-radius: 48rpx;
  padding: 28rpx 0;
  text-align: center;
  transition: opacity 0.2s;
}

.pay-btn.disabled {
  opacity: 0.5;
}

.pay-btn-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
}